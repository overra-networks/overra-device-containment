{
  "name": "overra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "DATABASE_URL=$DATABASE_URL prisma migrate dev",
    "db:deploy": "DATABASE_URL=$DATABASE_URL prisma migrate deploy",
    "db:generate": "DATABASE_URL=$DATABASE_URL prisma generate",
    "db:push": "DATABASE_URL=$DATABASE_URL prisma db push",
    "db:studio": "DATABASE_URL=$DATABASE_URL prisma studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:agent-contract": "bash tests/agent-contract/run.sh"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
