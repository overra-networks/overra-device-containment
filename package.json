    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
