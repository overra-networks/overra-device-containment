# ---------------------------------------------------------------------------
# Overra portal — production environment.
#
# Copy to /opt/overra/app/.env.production, fill every CHANGE_ME, then:
#   sudo chown overra:overra /opt/overra/app/.env.production
#   sudo chmod 600           /opt/overra/app/.env.production
#
# Generate a strong secret:  openssl rand -base64 48 | tr -d '\n'; echo
# NEVER commit the real file (.gitignore already excludes .env*).
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=3000

# Postgres on this VPS. Use a dedicated least-privilege role that OWNS the
# overra database — NOT the postgres superuser. Listener stays on localhost.
DATABASE_URL="postgresql://overra:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/overra?schema=public"

# Signs agent JWTs (365-day lifetime). 32+ chars. Rotating this invalidates
# EVERY deployed agent at once — pick it once and keep it.
JWT_SECRET="CHANGE_ME_openssl_rand_base64_48"

# Signs portal session cookies (NextAuth).
NEXTAUTH_SECRET="CHANGE_ME_openssl_rand_base64_48"

# MUST be the public HTTPS origin AFTER certbot has issued the cert.
# Wrong scheme/host here breaks login redirects and agent download URLs.
NEXTAUTH_URL="https://CHANGE_ME_DOMAIN"
APP_URL="https://CHANGE_ME_DOMAIN"

# Password-reset email delivery. The sender domain must be verified in
# Resend (SPF + DKIM) or messages go to spam. Leave RESEND_API_KEY blank
# only if you accept that password reset is non-functional.
RESEND_API_KEY="CHANGE_ME_re_xxx"
EMAIL_FROM="Overra <noreply@CHANGE_ME_DOMAIN>"
