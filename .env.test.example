# Copy to .env.test and fill in. Used by vitest setup and playwright.
# CRITICAL: DATABASE_URL must contain "overra_test" — tests refuse to run otherwise.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/overra_test"
JWT_SECRET="test-jwt-secret-min-32-characters-long-xxxxxx"
NEXTAUTH_SECRET="test-nextauth-secret-min-32-chars-xxxxxxxx"
NEXTAUTH_URL="http://localhost:3001"
E2E_PORT="3001"
