# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/playwright/.cache

# next.js
/.next/
/.next-e2e/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but committed templates with placeholder values are safe and required
!*.env.example
!.env.*.example
!deploy/.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Local dev builds — the production cross-compiled binaries in /agents/ are committed.
/overra-agent/agent
/overra-agent/agent.exe

# design-asset source files (large; keep out of source control)
/ASSETS+LOGO/
*.webm
*.docx
